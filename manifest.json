{
  "manifest_version": 3,
  "name": "Plugincy Support RPA",
  "version": "1.2.0",
  "description": "Draft customer-support replies through ChatGPT, escalate sensitive tickets, and manage a WordPress developer workbench.",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "alarms",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://hostinger.titan.email/*",
    "https://plugincy.com/wp-admin/admin.php*",
    "https://wordpress.org/*",
    "https://api.wordpress.org/*",
    "https://developer.woocommerce.com/*",
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Plugincy Workbench",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "chrome_url_overrides": {
    "newtab": "dashboard/newtab.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://hostinger.titan.email/*"
      ],
      "js": [
        "shared/workflow-core.js",
        "content/scraper.js",
        "content/source-notifier.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://plugincy.com/wp-admin/admin.php*"
      ],
      "js": [
        "shared/workflow-core.js",
        "content/scraper.js",
        "content/source-notifier.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content/prompt-builder.js",
        "content/gpt-controller.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
